<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".FirstFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <TextView
            android:id="@+id/textview_first"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BruScan"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="18dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aponte o leitor para o código e pressione o botão amarelo"
            android:textSize="18sp"
            android:textAlignment="center"
            android:layout_marginBottom="18dp" />

        <EditText
            android:id="@+id/edittext_produto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nome do produto opcional"
            android:textSize="18sp"
            android:textColor="#000000"
            android:textColorHint="#555555"
            android:padding="16dp"
            android:singleLine="true"
            android:background="#EEEEEE"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/edittext_codigo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="O código lido vai aparecer aqui"
            android:textSize="18sp"
            android:textColor="#000000"
            android:textColorHint="#555555"
            android:padding="16dp"
            android:singleLine="true"
            android:background="#EEEEEE"
            android:layout_marginBottom="18dp" />

        <TextView
            android:id="@+id/textview_status_exportacao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: aguardando leituras."
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:padding="16dp"
            android:background="#FFF9C4"
            android:layout_marginBottom="18dp" />

        <TextView
            android:id="@+id/textview_codigo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Último código lido: ---"
            android:textSize="18sp"
            android:textColor="#000000"
            android:padding="16dp"
            android:background="#DDDDDD"
            android:layout_marginBottom="18dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Resumo por produto"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/textview_resumo_produtos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nenhum produto nomeado ainda."
            android:textSize="16sp"
            android:textColor="#000000"
            android:padding="16dp"
            android:background="#EEEEEE"
            android:layout_marginBottom="18dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Histórico de leituras"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/textview_historico"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nenhuma leitura confirmada ainda."
            android:textSize="16sp"
            android:textColor="#000000"
            android:padding="16dp"
            android:background="#EEEEEE"
            android:layout_marginBottom="18dp" />

        <Button
            android:id="@+id/button_desfazer_ultima"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Desfazer última leitura"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/button_exportar_csv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Exportar CSV"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/button_compartilhar_csv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Compartilhar CSV"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/button_limpar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Limpar histórico"
            android:layout_marginBottom="24dp" />

    </LinearLayout>

</ScrollView>